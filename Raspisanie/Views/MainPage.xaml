                <StackLayout BackgroundColor="DarkCyan" HorizontalOptions="Center" HeightRequest="35" WidthRequest="321">
                    <Label x:Name="Status" Text="" TextColor="WhiteSmoke" HorizontalOptions="Center" VerticalOptions="CenterAndExpand"/>
                </StackLayout>
            </StackLayout>
        </StackLayout>
    </ContentPage>

