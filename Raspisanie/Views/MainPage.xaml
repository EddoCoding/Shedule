                                <StackLayout>
                                    <Label Text="Начало пары"/>
                                    <StackLayout Orientation="Horizontal">
                                        <Label x:Name="oneStartCouple" Text="{Binding InitialTimeCouple[0]}" Margin="0,0,5,0" FontSize="20"/>
